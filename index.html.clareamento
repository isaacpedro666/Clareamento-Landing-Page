<script>
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if(e.isIntersecting){ e.target.classList.add('visible'); observer.unobserve(e.target); } });
  }, { threshold: 0.1 });
  reveals.forEach(el => observer.observe(el));
  setTimeout(() => {
    reveals.forEach(el => { if(el.getBoundingClientRect().top < window.innerHeight) el.classList.add('visible'); });
  }, 100);

  const priceSec = document.getElementById('comprar');
  const stickyCta = document.querySelector('.sticky-cta');
  const priceObs = new IntersectionObserver((entries) => {
    stickyCta.style.display = entries[0].isIntersecting ? 'none' : 'block';
  }, { threshold: 0.2 });
  priceObs.observe(priceSec);
</script>
